# -----------------------------------------------------------------------------
# ATTENDANCE AI - ENVIRONMENT CONFIGURATION
# -----------------------------------------------------------------------------
# Copy this file to '.env' and fill in your actual connection strings.
# Do NOT commit your actual '.env' file to version control.

# MongoDB Database Connection
MONGO_URI=mongodb://localhost:27017
DB_NAME=attendance_db

# Shift Threshold Defaults (Fallback if MongoDB global_config is unreachable)
# Format: HH:MM:SS
LOGIN_TIME=09:30:00
LOGOUT_TIME=16:30:00

# FAISS Vector Search Similarity Threshold
SIMILARITY_THRESHOLD=0.70

# Frontend Variables
VITE_API_URL=http://localhost:8000/api
